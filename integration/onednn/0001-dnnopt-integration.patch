--- /dev/null
+++ b/src/cpu/aarch64/brgemm_sgemm_wrapper.hpp
@@ -0,0 +1,119 @@
+/*******************************************************************************
+* Copyright 2026 DNN-Opt Contributors
+*
+* BRGEMM fallback wrapper for oneDNN aarch64 dnnl_sgemm.
+* Uses oneDNN's native JIT-compiled brgemm kernel for large-M matmul,
+* avoiding dependency on ACL or slow ref_gemm.
+*
+* Licensed under the Apache License, Version 2.0
+*******************************************************************************/
+
+#ifndef CPU_AARCH64_BRGEMM_SGEMM_WRAPPER_HPP
+#define CPU_AARCH64_BRGEMM_SGEMM_WRAPPER_HPP
+
+#include "oneapi/dnnl/dnnl_types.h"
+#include "common/utils.hpp"
+#include "common/dnnl_thread.hpp"
+
+#include "cpu/aarch64/brgemm/brgemm.hpp"
+#include "cpu/aarch64/brgemm/brgemm_types.hpp"
+
+namespace dnnl {
+namespace impl {
+namespace cpu {
+namespace aarch64 {
+
+/// BRGEMM fallback for large-M sgemm.
+/// Uses oneDNN's native JIT brgemm kernel (no ACL dependency).
+///
+/// Performance: optimized for M >= 32, regular shapes.
+/// For M < 32, dnnopt small-M kernels are typically faster.
+///
+/// @param transa, transb  'N' or 'T' for transpose
+/// @param M, N, K  Matrix dimensions (column-major convention)
+/// @param alpha, beta  Scaling factors
+/// @param A, B, C  Matrix pointers
+/// @param lda, ldb, ldc  Leading dimensions
+/// @return dnnl_success or dnnl_unimplemented
+inline dnnl_status_t brgemm_sgemm_fallback(
+        const char *transa, const char *transb,
+        const dim_t *M, const dim_t *N, const dim_t *K,
+        const float *alpha,
+        const float *A, const dim_t *lda,
+        const float *B, const dim_t *ldb,
+        const float *beta,
+        float *C, const dim_t *ldc) {
+    // Early exit for trivial cases
+    if (*M == 0 || *N == 0) return dnnl_success;
+    if (*K == 0) {
+        if (*beta == 0.0f) {
+            for (dim_t j = 0; j < *N; j++)
+                std::memset(C + j * (*ldc), 0, *M * sizeof(float));
+        } else if (*beta != 1.0f) {
+            for (dim_t j = 0; j < *N; j++)
+                for (dim_t i = 0; i < *M; i++)
+                    C[j * (*ldc) + i] *= *beta;
+        }
+        return dnnl_success;
+    }
+
+    bool tA = (*transa == 'T' || *transa == 't');
+    bool tB = (*transb == 'T' || *transb == 't');
+
+    // Initialize BRGEMM descriptor for single-batch GEMM
+    brgemm_desc_t brg;
+    status_t st = brgemm_desc_init(&brg,
+            cpu_isa_t::isa_undef,  // auto-detect best ISA
+            brgemm_batch_kind_t::brgemm_addr,  // address-based batching
+            data_type::f32,  // dt_a
+            data_type::f32,  // dt_b
+            tA, tB,
+            brgemm_layout_t::brgemm_col_major,  // oneDNN uses column-major
+            *alpha, *beta,
+            *lda, *ldb, *ldc,
+            *M, *N, *K,
+            nullptr);  // no strides (single batch)
+
+    if (st != status::success) return dnnl_unimplemented;
+
+    // Finalize descriptor
+    st = brgemm_desc_finalize(&brg);
+    if (st != status::success) return dnnl_unimplemented;
+
+    // Create kernel (JIT compilation)
+    brgemm_kernel_t *brg_kernel = nullptr;
+    st = brgemm_kernel_create(&brg_kernel, brg);
+    if (st != status::success) return dnnl_unimplemented;
+
+    // Prepare batch element (single matrix pair)
+    brgemm_batch_element_t batch;
+    batch.ptr.A = static_cast<const void *>(A);
+    batch.ptr.B = static_cast<const void *>(B);
+    batch.vvpad.top = 0;
+    batch.vvpad.bottom = 0;
+
+    // Execute BRGEMM with batch size = 1
+    brgemm_kernel_execute(brg_kernel, 1, &batch, C, nullptr);
+
+    // Cleanup
+    brgemm_kernel_destroy(brg_kernel);
+
+    return dnnl_success;
+}
+
+/// Check if BRGEMM should be used for given shape.
+/// BRGEMM is efficient for large regular shapes, dnnopt for small-M.
+inline bool should_use_brgemm(dim_t M, dim_t N, dim_t K) {
+    // BRGEMM threshold based on benchmark results:
+    // - M >= 32: BRGEMM competitive
+    // - M >= 64: BRGEMM often faster than dnnopt for regular shapes
+    // - Irregular shapes (very small N/K): dnnopt handles edge cases better
+    return M >= 64 && N >= 64 && K >= 64;
+}
+
+} // namespace aarch64
+} // namespace cpu
+} // namespace impl
+} // namespace dnnl
+
+#endif // CPU_AARCH64_BRGEMM_SGEMM_WRAPPER_HPP
\ No newline at end of file
