+/// Drop-in replacement for gemm_bf16bf16f32() that dispatches to DNN-Opt.
+///
+/// gemm_bf16bf16f32 uses Fortran/column-major convention:
+///   C(M×N, col-major, ldc) = alpha * op(A) * op(B) + beta * C
+///   where A and B are bfloat16 matrices.
+///
+/// Same column-major to row-major duality as dnnopt_sgemm.
+inline dnnl_status_t dnnopt_gemm_bf16bf16f32(const char *transa, const char *transb,
+        const dim_t *M, const dim_t *N, const dim_t *K, const float *alpha,
+        const bfloat16_t *A, const dim_t *lda, const bfloat16_t *B, const dim_t *ldb,
+        const float *beta, float *C, const dim_t *ldc) {
+    // Early exit
+    if (*M == 0 || *N == 0) return dnnl_success;
+    if (*K == 0) {
+        if (*beta == 0.0f) {
+            for (dim_t j = 0; j < *N; j++)
+                std::memset(C + j * (*ldc), 0, *M * sizeof(float));
+        } else if (*beta != 1.0f) {
+            for (dim_t j = 0; j < *N; j++)
+                for (dim_t i = 0; i < *M; i++)
+                    C[j * (*ldc) + i] *= *beta;
+        }
+        return dnnl_success;
+    }
+
+    bool tA = (*transa == 'T' || *transa == 't');
+    bool tB = (*transb == 'T' || *transb == 't');
+
+    // Col-major to row-major duality (same as FP32):
+    //   ColMajor(trA, trB, M, N, K, A, lda, B, ldb, C, ldc)
+    //   = RowMajor(trB, trA, N, M, K, B, ldb, A, lda, C, ldc)
+    int rm_M = (int)*N;
+    int rm_N = (int)*M;
+    int rm_K = (int)*K;
+
+    // Cast oneDNN bfloat16_t* to dnnopt::bfloat16_t*
+    // Both have identical layout (uint16_t raw_bits/raw_bits_)
+    const dnnopt::bfloat16_t *A_dnnopt = reinterpret_cast<const dnnopt::bfloat16_t*>(A);
+    const dnnopt::bfloat16_t *B_dnnopt = reinterpret_cast<const dnnopt::bfloat16_t*>(B);
+
+    if ((int)*ldc >= rm_N) {
+        dnnopt_gemm_bf16_row_major(tB, tA, rm_M, rm_N, rm_K, *alpha,
+                B_dnnopt, (int)*ldb, A_dnnopt, (int)*lda,
+                *beta, C, (int)*ldc);
+    } else {
+        int safe_ldc = rm_N;
+        auto tmp = dnnopt::aligned_array<float>((size_t)rm_M * safe_ldc);
+
+        if (*beta != 0.0f) {
+            for (int r = 0; r < rm_M; r++)
+                for (int c = 0; c < rm_N; c++)
+                    tmp[r * safe_ldc + c] = C[r * (int)*ldc + c];
+        }
+
+        dnnopt_gemm_bf16_row_major(tB, tA, rm_M, rm_N, rm_K, *alpha,
+                B_dnnopt, (int)*ldb, A_dnnopt, (int)*lda,
+                *beta, tmp.get(), safe_ldc);
+
+        for (int r = 0; r < rm_M; r++)
+            for (int c = 0; c < rm_N; c++)
+                C[r * (int)*ldc + c] = tmp[r * safe_ldc + c];
+    }
+
+    return dnnl_success;
+}
+
 } // namespace aarch64
 } // namespace cpu
 } // namespace impl
