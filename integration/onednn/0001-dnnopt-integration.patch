+++ b/cmake/dnnopt.cmake
@@ -0,0 +1,65 @@
+# *******************************************************************************
+# Copyright 2026 DNN-Opt Contributors
+# SPDX-License-Identifier: Apache-2.0
+# *******************************************************************************
+
+if(dnnopt_cmake_included)
+    return()
+endif()
+set(dnnopt_cmake_included true)
+
+if(NOT DNNL_AARCH64_USE_DNNOPT)
+    return()
+endif()
+
+if(NOT "${DNNL_TARGET_ARCH}" STREQUAL "AARCH64")
+    message(WARNING "DNNL_AARCH64_USE_DNNOPT is only supported on AArch64. Disabling.")
+    set(DNNL_AARCH64_USE_DNNOPT OFF CACHE BOOL "" FORCE)
+    return()
+endif()
+
+# Find DNN-Opt installation
+if(NOT DNNOPT_ROOT)
+    set(DNNOPT_ROOT "/root/onednn-arm-opt" CACHE PATH "Path to DNN-Opt source root")
+endif()
+
+set(DNNOPT_INCLUDE_DIR "${DNNOPT_ROOT}/include")
+set(DNNOPT_LIBRARY "${DNNOPT_ROOT}/build/src/libdnnopt_core.a")
+
+# Validate paths
+if(NOT EXISTS "${DNNOPT_INCLUDE_DIR}/dnnopt/gemm/gemm.h")
+    message(FATAL_ERROR "DNN-Opt headers not found at ${DNNOPT_INCLUDE_DIR}. "
+        "Set DNNOPT_ROOT to the DNN-Opt source directory.")
+endif()
+
+if(NOT EXISTS "${DNNOPT_LIBRARY}")
+    message(FATAL_ERROR "DNN-Opt library not found at ${DNNOPT_LIBRARY}. "
+        "Build DNN-Opt first: cd ${DNNOPT_ROOT}/build && cmake .. && make")
+endif()
+
+message(STATUS "Found DNN-Opt: ${DNNOPT_LIBRARY}")
+message(STATUS "DNN-Opt include: ${DNNOPT_INCLUDE_DIR}")
+
+# Create imported target
+add_library(dnnopt::core STATIC IMPORTED)
+set_target_properties(dnnopt::core PROPERTIES
+    IMPORTED_LOCATION "${DNNOPT_LIBRARY}"
+    INTERFACE_INCLUDE_DIRECTORIES "${DNNOPT_INCLUDE_DIR}"
+)
+
+# DNN-Opt uses OpenMP for threading
+find_package(OpenMP)
+if(OpenMP_CXX_FOUND)
+    set_target_properties(dnnopt::core PROPERTIES
+        INTERFACE_LINK_LIBRARIES "OpenMP::OpenMP_CXX"
+    )
+endif()
+
+# Add compile definition so source code can detect DNN-Opt
+add_definitions(-DDNNL_USE_DNNOPT)
+
+# Include DNN-Opt headers in the build
+include_directories(SYSTEM ${DNNOPT_INCLUDE_DIR})
+
+# Link DNN-Opt to the main library
+list(APPEND EXTRA_STATIC_LIBS dnnopt::core)
