+// Fast NEON-accelerated transpose: dst[cols, rows] = src[rows, cols]^T
+// Both src and dst are row-major. dst has ld_dst >= rows (columns of output).
+inline void neon_transpose_f32(const float *src, float *dst,
+        int rows, int cols, int ld_src, int ld_dst) {
+    int r = 0;
+#ifdef __ARM_NEON
+    for (; r + 3 < rows; r += 4) {
+        int c = 0;
+        for (; c + 3 < cols; c += 4) {
+            float32x4_t r0 = vld1q_f32(src + (r + 0) * ld_src + c);
+            float32x4_t r1 = vld1q_f32(src + (r + 1) * ld_src + c);
+            float32x4_t r2 = vld1q_f32(src + (r + 2) * ld_src + c);
+            float32x4_t r3 = vld1q_f32(src + (r + 3) * ld_src + c);
+            float32x4x2_t t01 = vzipq_f32(r0, r2);
+            float32x4x2_t t23 = vzipq_f32(r1, r3);
+            float32x4x2_t u0 = vzipq_f32(t01.val[0], t23.val[0]);
+            float32x4x2_t u1 = vzipq_f32(t01.val[1], t23.val[1]);
+            vst1q_f32(dst + (c + 0) * ld_dst + r, u0.val[0]);
+            vst1q_f32(dst + (c + 1) * ld_dst + r, u0.val[1]);
+            vst1q_f32(dst + (c + 2) * ld_dst + r, u1.val[0]);
+            vst1q_f32(dst + (c + 3) * ld_dst + r, u1.val[1]);
+        }
+        for (; c < cols; ++c)
+            for (int rr = r; rr < r + 4; ++rr)
+                dst[c * ld_dst + rr] = src[rr * ld_src + c];
+    }
+#endif
+    for (; r < rows; ++r)
+        for (int c = 0; c < cols; ++c)
+            dst[c * ld_dst + r] = src[r * ld_src + c];
+}
+
+// Minimum stride for DNN-Opt GEMM micro-kernel output.
+// The kernel writes full tiles (e.g., 8x12), so ldc must be >= tile_n.
+static constexpr int DNNOPT_MIN_LDC = 12;
+
+// Safe wrapper around dnnopt::gemm_fp32 that handles small ldc.
+// When ldc < DNNOPT_MIN_LDC, uses a temporary output buffer with adequate
+// stride, then copies the result back.
+inline void safe_gemm_fp32(int M, int N, int K, float alpha,
+        const float *A, int lda, const float *B, int ldb,
+        float beta, float *C, int ldc) {
+    if (N >= DNNOPT_MIN_LDC || ldc >= DNNOPT_MIN_LDC) {
+        // Normal path: stride is large enough for the kernel tile
+        dnnopt::gemm_fp32(M, N, K, alpha, A, lda, B, ldb, beta, C, ldc);
+    } else {
+        // Small N: use temporary buffer with safe stride
+        int safe_ldc = DNNOPT_MIN_LDC;
+        auto tmp = dnnopt::aligned_array<float>((size_t)M * safe_ldc);
+
+        // Copy existing C to tmp (for beta != 0)
+        if (beta != 0.0f) {
+            for (int i = 0; i < M; i++)
+                for (int j = 0; j < N; j++)
+                    tmp[i * safe_ldc + j] = C[i * ldc + j];
+        }
+
+        dnnopt::gemm_fp32(M, N, K, alpha, A, lda, B, ldb, beta, tmp.get(), safe_ldc);
+
+        // Copy result back to C
+        for (int i = 0; i < M; i++)
+            for (int j = 0; j < N; j++)
+                C[i * ldc + j] = tmp[i * safe_ldc + j];
+    }
+}
+
+// Row-major GEMM with transpose support via DNN-Opt.
+inline void dnnopt_gemm_row_major(bool transA, bool transB,
+        int M, int N, int K, float alpha,
+        const float *A, int lda, const float *B, int ldb,
+        float beta, float *C, int ldc) {
+    if (!transA && !transB) {
+        safe_gemm_fp32(M, N, K, alpha, A, lda, B, ldb, beta, C, ldc);
+    } else if (transA && !transB) {
+        // A stored as K×M row-major → transpose to M×K
+        auto A_T = dnnopt::aligned_array<float>((size_t)M * K);
+        neon_transpose_f32(A, A_T.get(), K, M, lda, K);
+        safe_gemm_fp32(M, N, K, alpha, A_T.get(), K, B, ldb, beta, C, ldc);
+    } else if (!transA && transB) {
+        // B stored as N×K row-major → transpose to K×N
+        auto B_T = dnnopt::aligned_array<float>((size_t)K * N);
+        neon_transpose_f32(B, B_T.get(), N, K, ldb, N);
+        safe_gemm_fp32(M, N, K, alpha, A, lda, B_T.get(), N, beta, C, ldc);
+    } else {
+        auto A_T = dnnopt::aligned_array<float>((size_t)M * K);
+        auto B_T = dnnopt::aligned_array<float>((size_t)K * N);
+        neon_transpose_f32(A, A_T.get(), K, M, lda, K);
+        neon_transpose_f32(B, B_T.get(), N, K, ldb, N);
+        safe_gemm_fp32(M, N, K, alpha, A_T.get(), K, B_T.get(), N,
+                beta, C, ldc);
+    }
+}
+
+} // anonymous namespace
