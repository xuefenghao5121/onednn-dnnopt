+// ============================================================================
+// BF16 GEMM support
+// ============================================================================
+
+// Fast BF16 transpose: dst[cols, rows] = src[rows, cols]^T
+// Both src and dst are row-major bfloat16 matrices.
+inline void neon_transpose_bf16(const dnnopt::bfloat16_t *src, dnnopt::bfloat16_t *dst,
+        int rows, int cols, int ld_src, int ld_dst) {
+    int r = 0;
+#ifdef __ARM_NEON
+    // Process 8x8 blocks for BF16 (8 elements per vector)
+    for (; r + 7 < rows; r += 8) {
+        int c = 0;
+        for (; c + 7 < cols; c += 8) {
+            // Load 8 rows × 8 cols
+            uint16x8_t row0 = vld1q_u16(reinterpret_cast<const uint16_t*>(src + (r + 0) * ld_src + c));
+            uint16x8_t row1 = vld1q_u16(reinterpret_cast<const uint16_t*>(src + (r + 1) * ld_src + c));
+            uint16x8_t row2 = vld1q_u16(reinterpret_cast<const uint16_t*>(src + (r + 2) * ld_src + c));
+            uint16x8_t row3 = vld1q_u16(reinterpret_cast<const uint16_t*>(src + (r + 3) * ld_src + c));
+            uint16x8_t row4 = vld1q_u16(reinterpret_cast<const uint16_t*>(src + (r + 4) * ld_src + c));
+            uint16x8_t row5 = vld1q_u16(reinterpret_cast<const uint16_t*>(src + (r + 5) * ld_src + c));
+            uint16x8_t row6 = vld1q_u16(reinterpret_cast<const uint16_t*>(src + (r + 6) * ld_src + c));
+            uint16x8_t row7 = vld1q_u16(reinterpret_cast<const uint16_t*>(src + (r + 7) * ld_src + c));
+
+            // Transpose 8x8: use 4 rounds of zip
+            uint16x8x2_t t0 = vzipq_u16(row0, row2);
+            uint16x8x2_t t1 = vzipq_u16(row1, row3);
+            uint16x8x2_t t2 = vzipq_u16(row4, row6);
+            uint16x8x2_t t3 = vzipq_u16(row5, row7);
+
+            uint16x8x2_t u0 = vzipq_u16(t0.val[0], t1.val[0]);
+            uint16x8x2_t u1 = vzipq_u16(t0.val[1], t1.val[1]);
+            uint16x8x2_t u2 = vzipq_u16(t2.val[0], t3.val[0]);
+            uint16x8x2_t u3 = vzipq_u16(t2.val[1], t3.val[1]);
+
+            // Reinterpret as uint32 for final zip
+            uint32x4x2_t v0 = vzipq_u32(vreinterpretq_u32_u16(u0.val[0]), vreinterpretq_u32_u16(u2.val[0]));
+            uint32x4x2_t v1 = vzipq_u32(vreinterpretq_u32_u16(u0.val[1]), vreinterpretq_u32_u16(u2.val[1]));
+            uint32x4x2_t v2 = vzipq_u32(vreinterpretq_u32_u16(u1.val[0]), vreinterpretq_u32_u16(u3.val[0]));
+            uint32x4x2_t v3 = vzipq_u32(vreinterpretq_u32_u16(u1.val[1]), vreinterpretq_u32_u16(u3.val[1]));
+
+            // Store transposed: col i of src becomes row i of dst
+            vst1q_u16(reinterpret_cast<uint16_t*>(dst + (c + 0) * ld_dst + r), vreinterpretq_u16_u32(v0.val[0]));
+            vst1q_u16(reinterpret_cast<uint16_t*>(dst + (c + 1) * ld_dst + r), vreinterpretq_u16_u32(v1.val[0]));
+            vst1q_u16(reinterpret_cast<uint16_t*>(dst + (c + 2) * ld_dst + r), vreinterpretq_u16_u32(v2.val[0]));
+            vst1q_u16(reinterpret_cast<uint16_t*>(dst + (c + 3) * ld_dst + r), vreinterpretq_u16_u32(v3.val[0]));
+            vst1q_u16(reinterpret_cast<uint16_t*>(dst + (c + 4) * ld_dst + r), vreinterpretq_u16_u32(v0.val[1]));
+            vst1q_u16(reinterpret_cast<uint16_t*>(dst + (c + 5) * ld_dst + r), vreinterpretq_u16_u32(v1.val[1]));
+            vst1q_u16(reinterpret_cast<uint16_t*>(dst + (c + 6) * ld_dst + r), vreinterpretq_u16_u32(v2.val[1]));
+            vst1q_u16(reinterpret_cast<uint16_t*>(dst + (c + 7) * ld_dst + r), vreinterpretq_u16_u32(v3.val[1]));
+        }
+        // Handle remaining columns
+        for (; c < cols; ++c)
+            for (int rr = r; rr < r + 8; ++rr)
+                dst[c * ld_dst + rr] = src[rr * ld_src + c];
+    }
+#endif
+    // Handle remaining rows
+    for (; r < rows; ++r)
+        for (int c = 0; c < cols; ++c)
+            dst[c * ld_dst + r] = src[r * ld_src + c];
+}
+
+// Minimum stride for BF16 microkernel output (8x8 tile)
+static constexpr int DNNOPT_BF16_MIN_LDC = 8;
+
+// Safe wrapper around dnnopt::gemm_bf16_bf16bf16f32 that handles small ldc.
+inline void safe_gemm_bf16_bf16bf16f32(int M, int N, int K, float alpha,
+        const dnnopt::bfloat16_t *A, int lda, const dnnopt::bfloat16_t *B, int ldb,
+        float beta, float *C, int ldc) {
+    if (N >= DNNOPT_BF16_MIN_LDC || ldc >= DNNOPT_BF16_MIN_LDC) {
+        dnnopt::gemm_bf16_bf16bf16f32(M, N, K, alpha, A, lda, B, ldb, beta, C, ldc);
+    } else {
+        int safe_ldc = DNNOPT_BF16_MIN_LDC;
+        auto tmp = dnnopt::aligned_array<float>((size_t)M * safe_ldc);
+
+        if (beta != 0.0f) {
+            for (int i = 0; i < M; i++)
+                for (int j = 0; j < N; j++)
+                    tmp[i * safe_ldc + j] = C[i * ldc + j];
+        }
+
+        dnnopt::gemm_bf16_bf16bf16f32(M, N, K, alpha, A, lda, B, ldb, beta, tmp.get(), safe_ldc);
+
+        for (int i = 0; i < M; i++)
+            for (int j = 0; j < N; j++)
+                C[i * ldc + j] = tmp[i * safe_ldc + j];
+    }
+}
+
+// Row-major BF16 GEMM with transpose support via DNN-Opt.
+inline void dnnopt_gemm_bf16_row_major(bool transA, bool transB,
+        int M, int N, int K, float alpha,
+        const dnnopt::bfloat16_t *A, int lda, const dnnopt::bfloat16_t *B, int ldb,
+        float beta, float *C, int ldc) {
+    if (!transA && !transB) {
+        safe_gemm_bf16_bf16bf16f32(M, N, K, alpha, A, lda, B, ldb, beta, C, ldc);
+    } else if (transA && !transB) {
+        auto A_T = dnnopt::aligned_array<dnnopt::bfloat16_t>((size_t)M * K);
+        neon_transpose_bf16(A, A_T.get(), K, M, lda, K);
+        safe_gemm_bf16_bf16bf16f32(M, N, K, alpha, A_T.get(), K, B, ldb, beta, C, ldc);
+    } else if (!transA && transB) {
+        auto B_T = dnnopt::aligned_array<dnnopt::bfloat16_t>((size_t)K * N);
+        neon_transpose_bf16(B, B_T.get(), N, K, ldb, N);
+        safe_gemm_bf16_bf16bf16f32(M, N, K, alpha, A, lda, B_T.get(), N, beta, C, ldc);
+    } else {
+        auto A_T = dnnopt::aligned_array<dnnopt::bfloat16_t>((size_t)M * K);
+        auto B_T = dnnopt::aligned_array<dnnopt::bfloat16_t>((size_t)K * N);
+        neon_transpose_bf16(A, A_T.get(), K, M, lda, K);
+        neon_transpose_bf16(B, B_T.get(), N, K, ldb, N);
+        safe_gemm_bf16_bf16bf16f32(M, N, K, alpha, A_T.get(), K, B_T.get(), N, beta, C, ldc);
+    }
+}
+
