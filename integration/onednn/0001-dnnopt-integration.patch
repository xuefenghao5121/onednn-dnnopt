@@ -164,10 +168,7 @@ dnnl_status_t extended_sgemm(const char *transa, const char *transb,
     // Performance profile (Neoverse N2 benchmark):
     //   - M < 32: dnnopt 1.7x-6.1x faster than upstream (CVR/LLM batch inference)
     //   - M = 32: dnnopt ~same as upstream (BERT/LLM b32)
-    //   - M >= 64: dnnopt 0.7x slower than upstream (BERT b128), but still
-    //              faster than ref_gemm fallback
-    // TODO: Integrate ACL gemm for large-M fallback, or optimize dnnopt's
-    //       large-M kernels to match upstream performance.
+    //   - M >= 64: dnnopt slower for regular shapes but beats ref_gemm
     {
         auto status = aarch64::dnnopt_sgemm(transa, transb, M, N, K, alpha,
                 A, lda, B, ldb, beta, C, ldc, bias);
@@ -175,6 +176,17 @@ dnnl_status_t extended_sgemm(const char *transa, const char *transb,
     }
 #endif
 
+#if DNNL_AARCH64
+    // BRGEMM fallback: oneDNN's native JIT kernel (no ACL dependency)
+    // Used when dnnopt returns unimplemented, or for very large shapes.
+    // Note: JIT compilation overhead per call - consider kernel caching for hot paths.
